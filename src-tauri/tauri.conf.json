{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noema",
  "version": "0.1.0",
  "identifier": "app.Noema.Noema",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Noema",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": ""
    },
    "shortDescription": "Local-first AI-powered knowledge assistant",
    "longDescription": "Noema scans your markdown notes, chunks and embeds them with Ollama, and lets you search and ask questions across your knowledge base."
  }
}
